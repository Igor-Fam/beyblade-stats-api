// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model PartType {
  id               Int               @id @default(autoincrement())
  name             String            @unique
  parts            Part[]

  @@map("part_types")
}

model Line {
  id               Int               @id @default(autoincrement())
  name             String            @unique
  battleEntries    BattleEntry[]
  parts            Part[]

  @@map("lines")
}

model Part {
  id            Int               @id @default(autoincrement())
  name          String
  abbreviation  String?
  partTypeId    Int               @map("part_type_id")
  partType      PartType          @relation(fields: [partTypeId], references: [id])
  battleEntries BattleEntryPart[]
  lineId        Int?              @map("line_id")
  line          Line?             @relation(fields: [lineId], references: [id])
  metadata      Json?

  @@map("parts")
}

model Battle {
  id        Int           @id @default(autoincrement())
  createdAt DateTime      @default(now()) @map("created_at")
  entries   BattleEntry[]

  @@map("battles")
}

model BattleEntry {
  id         Int               @id @default(autoincrement())
  battleId   Int               @map("battle_id")
  lineId     Int               @map("line_id")
  finishType String            @map("finish_type")
  points     Int
  comboHash  String            @map("combo_hash")
  battle     Battle            @relation(fields: [battleId], references: [id], onDelete: Cascade)
  line       Line              @relation(fields: [lineId], references: [id])
  parts      BattleEntryPart[]

  @@map("battle_entries")
}

model BattleEntryPart {
  battleEntryId Int         @map("battle_entry_id")
  partId        Int         @map("part_id")
  battleEntry   BattleEntry @relation(fields: [battleEntryId], references: [id], onDelete: Cascade)
  part          Part        @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@id([battleEntryId, partId])
  @@map("battle_entry_parts")
}